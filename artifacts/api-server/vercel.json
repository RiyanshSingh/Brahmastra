{
  "version": 2,
  "buildCommand": "npm install && node ./build.mjs && mkdir -p public",
  "outputDirectory": "public",
  "functions": {
    "api/[...route].js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/[...route].js"
    }
  ]
}
